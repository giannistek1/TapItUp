<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TapItUp.SongSelectPage"
             Title="Song Select"
             BackgroundColor="#05010F"
             NavigationPage.HasNavigationBar="False">

    <Grid x:Name="MainGrid">
        <!-- Portrait Layout -->
        <Grid x:Name="PortraitLayout"
              IsVisible="True"
              Padding="{OnPlatform Default=16, iOS=8, Android=8}"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">

            <!-- Row 0: Header -->
            <VerticalStackLayout Grid.Row="0" Spacing="1" Margin="0,0,0,4">
                <Label Text="TAP IT UP"
                       FontSize="{OnPlatform Default=24, iOS=20, Android=20}"
                       FontAttributes="Bold"
                       TextColor="#FFF4FF"
                       HorizontalTextAlignment="Center" />
                <Label Text="Select a series and song to play"
                       FontSize="{OnPlatform Default=12, iOS=10, Android=10}"
                       TextColor="#D0B7FF"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Row 1: Load buttons -->
            <HorizontalStackLayout Grid.Row="1" Spacing="8" HorizontalOptions="Center" Margin="0,0,0,4">
                <Button Text="External Folder"
                        Clicked="OnOpenFolderClicked"
                        BackgroundColor="#5D42E6"
                        TextColor="White"
                        CornerRadius="10"
                        WidthRequest="{OnPlatform Default=160, iOS=140, Android=140}"
                        HeightRequest="{OnPlatform Default=44, iOS=40, Android=40}"
                        FontSize="{OnPlatform Default=14, iOS=12, Android=12}" />
                <Button x:Name="LoadRemoteButtonPortrait" Text="Load from URL" Clicked="OnLoadRemoteClicked" />
            </HorizontalStackLayout>

            <!-- Row 2: Loading progress -->
            <VerticalStackLayout Grid.Row="2" Spacing="4">
                <Label x:Name="LoadingLabelPortrait"
                       Text=""
                       TextColor="#D0B7FF"
                       FontSize="12"
                       IsVisible="False"
                       HorizontalTextAlignment="Center"/>
                <ProgressBar x:Name="LoadingProgressBarPortrait"
                             Progress="0"
                             IsVisible="False"
                             HeightRequest="6"
                             BackgroundColor="#2A1B4A"
                             ProgressColor="#D94BFF"/>
            </VerticalStackLayout>

            <!-- Row 3: Commands toggle + collapsible settings panel -->
            <VerticalStackLayout Grid.Row="3" Spacing="0" Margin="0,0,0,8">

                <Button Text="{Binding CommandsButtonText}"
                        Clicked="OnCommandsToggled"
                        BackgroundColor="#2A1B4A"
                        TextColor="#D0B7FF"
                        CornerRadius="8"
                        HeightRequest="{OnPlatform Default=36, iOS=32, Android=32}"
                        FontSize="{OnPlatform Default=13, iOS=11, Android=11}"
                        FontAttributes="Bold"
                        HorizontalOptions="FillAndExpand"
                        Margin="0,0,0,4"/>

                <Border IsVisible="{Binding IsSettingsVisible}"
                        Background="#1A102A"
                        Stroke="#4C327C"
                        StrokeThickness="1"
                        Padding="{OnPlatform Default=12, iOS=8, Android=8}"
                        StrokeShape="RoundRectangle 8">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">

                        <!-- Row 0: AV slider -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Label Grid.Column="0"
                                   Text="AV"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   VerticalTextAlignment="Center" />
                            <Slider Grid.Column="1"
                                    x:Name="PortraitScrollSpeedSlider"
                                    Minimum="300"
                                    Maximum="999"
                                    Value="{Binding Av}"
                                    ValueChanged="OnAvChanged"
                                    ThumbColor="#D94BFF"
                                    MinimumTrackColor="#A100FF"
                                    MaximumTrackColor="#4C327C" />
                            <Label Grid.Column="2"
                                   x:Name="PortraitScrollSpeedLabel"
                                   Text="{Binding AvText}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FFE76A"
                                   VerticalTextAlignment="Center"
                                   MinimumWidthRequest="45"
                                   HorizontalTextAlignment="Center" />
                        </Grid>

                        <!-- Row 1: Audio offset slider -->
                        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Label Grid.Column="0"
                                   Text="Offset"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   VerticalTextAlignment="Center"
                                   ToolTipProperties.Text="Audio offset: positive = arrows later (use for Bluetooth lag)" />
                            <Slider Grid.Column="1"
                                    x:Name="PortraitAudioOffsetSlider"
                                    Minimum="0"
                                    Maximum="4000"
                                    Value="{Binding AudioOffsetMs}"
                                    ValueChanged="OnAudioOffsetChanged"
                                    ThumbColor="#00C2FF"
                                    MinimumTrackColor="#0090CC"
                                    MaximumTrackColor="#4C327C" />
                            <Label Grid.Column="2"
                                   Text="{Binding AudioOffsetText}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#00C2FF"
                                   VerticalTextAlignment="Center"
                                   MinimumWidthRequest="68"
                                   HorizontalTextAlignment="Center" />
                        </Grid>

                        <!-- Row 2: Note skin + Judgment -->
                        <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12">
                            <Label Text="Note Skin"
                                   FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   VerticalTextAlignment="Center" />
                            <Picker Grid.Column="1"
                                    x:Name="NoteSkinPicker"
                                    SelectedItem="{Binding NoteSkin}"
                                    TextColor="#FFF4FF"
                                    TitleColor="#8C76B5"
                                    FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                                    HeightRequest="{OnPlatform Default=40, iOS=35, Android=35}"
                                    WidthRequest="100">
                                <Picker.Items>
                                    <x:String>Prime</x:String>
                                    <x:String>Fiestaex</x:String>
                                    <x:String>Old</x:String>
                                    <x:String>NXA</x:String>
                                </Picker.Items>
                            </Picker>
                            <Label Grid.Column="2"
                                   Text="Judge"
                                   FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   VerticalTextAlignment="Center" />
                            <Picker Grid.Column="3"
                                    SelectedItem="{Binding JudgmentDifficultyString}"
                                    TextColor="#FFF4FF"
                                    TitleColor="#8C76B5"
                                    FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                                    HeightRequest="{OnPlatform Default=40, iOS=35, Android=35}"
                                    WidthRequest="110">
                                <Picker.Items>
                                    <x:String>Standard</x:String>
                                    <x:String>Hard</x:String>
                                </Picker.Items>
                            </Picker>
                        </Grid>

                        <!-- Row 3: Animations toggle -->
                        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Label Grid.Column="0"
                                   Text="Animations"
                                   FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   VerticalTextAlignment="Center" />
                            <Label Grid.Column="1"
                                   Text="(disable on low-end devices)"
                                   FontSize="{OnPlatform Default=11, iOS=10, Android=10}"
                                   TextColor="#8C76B5"
                                   VerticalTextAlignment="Center" />
                            <Switch Grid.Column="2"
                                    x:Name="AnimationsSwitch"
                                    IsToggled="{Binding AnimationsEnabled}"
                                    OnColor="#D94BFF"
                                    ThumbColor="#FFF4FF" />
                        </Grid>

                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- Row 4: Back button + search bar -->
            <Grid Grid.Row="4"
                  ColumnDefinitions="Auto,*"
                  ColumnSpacing="8"
                  Margin="0,0,0,6">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackToSeriesClicked"
                        BackgroundColor="#5D42E6"
                        TextColor="White"
                        CornerRadius="10"
                        WidthRequest="{OnPlatform Default=44, iOS=40, Android=40}"
                        HeightRequest="{OnPlatform Default=44, iOS=40, Android=40}"
                        FontSize="{OnPlatform Default=18, iOS=16, Android=16}"
                        IsVisible="{Binding IsSongListVisible}" />
                <Border Grid.Column="1"
                        Background="#1A102A"
                        Stroke="#4C327C"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="8,2">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="4">
                        <Label Grid.Column="0"
                               Text="🔍"
                               FontSize="16"
                               TextColor="#8C76B5"
                               VerticalTextAlignment="Center" />
                        <Entry Grid.Column="1"
                               x:Name="PortraitSearchEntry"
                               Placeholder="Search all songs…"
                               Text="{Binding SearchText}"
                               TextChanged="OnSearchTextChanged"
                               PlaceholderColor="#8C76B5"
                               TextColor="#FFF4FF"
                               BackgroundColor="Transparent"
                               ClearButtonVisibility="WhileEditing" />
                        <Label Grid.Column="2"
                               Text="{Binding SearchResults.Count, StringFormat='{0} results'}"
                               FontSize="11"
                               TextColor="#8C76B5"
                               VerticalTextAlignment="Center"
                               IsVisible="{Binding IsSearchActive}" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 5: Series selector -->
            <CollectionView Grid.Row="5"
                            x:Name="PortraitSeriesCollectionView"
                            ItemsSource="{Binding GameSeriesList}"
                            SelectionMode="Single"
                            SelectionChanged="OnSeriesSelected"
                            IsVisible="{Binding IsSeriesViewVisible}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="#4C327C"
                                StrokeThickness="1"
                                Background="#1A102A"
                                StrokeShape="RoundRectangle 16"
                                Padding="0"
                                WidthRequest="180"
                                HeightRequest="120">
                            <Grid>
                                <Image Source="{Binding Banner}" Aspect="AspectFill" />
                                <BoxView BackgroundColor="#000000" Opacity="0.4"/>
                                <Label Text="{Binding Name}"
                                       TextColor="White"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="End"
                                       Margin="0,0,0,10"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Row 5: Song list -->
            <CollectionView Grid.Row="5"
                            x:Name="SongListView"
                            ItemsSource="{Binding SongList}"
                            SelectionMode="Single"
                            SelectionChanged="OnSongSelected"
                            ItemsLayout="VerticalList"
                            IsVisible="{Binding IsSongListVisible}">
                <CollectionView.EmptyView>
                    <Label Text="Loading song collection..."
                           TextColor="#8C76B5"
                           FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           Margin="0,40" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,1,0,1"
                                Padding="6,4,6,4"
                                Stroke="#4C327C"
                                StrokeThickness="1"
                                Background="#1A102A"
                                StrokeShape="RoundRectangle 6">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="1">
                                <Image Grid.RowSpan="3" Grid.ColumnSpan="2"
                                       Source="{Binding BackgroundImageSource}"
                                       Aspect="AspectFill"
                                       Opacity="0.2"
                                       HorizontalOptions="FillAndExpand"
                                       VerticalOptions="FillAndExpand" />
                                <BoxView Grid.RowSpan="3" Grid.ColumnSpan="2"
                                         BackgroundColor="#1A102A"
                                         Opacity="0.2" />
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                                       TextColor="#FFF4FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Artist}"
                                       FontSize="{OnPlatform Default=11, iOS=9, Android=9}"
                                       TextColor="#D0B7FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="2" Grid.Column="0"
                                       Text="{Binding ChartSummary}"
                                       FontSize="{OnPlatform Default=10, iOS=8, Android=8}"
                                       TextColor="#FFE76A"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Grid.RowSpan="3"
                                       Text="▶"
                                       FontSize="{OnPlatform Default=16, iOS=14, Android=14}"
                                       TextColor="#D94BFF"
                                       VerticalTextAlignment="Center"
                                       Margin="6,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Row 5: Search results -->
            <CollectionView Grid.Row="5"
                            x:Name="PortraitSearchResultsView"
                            ItemsSource="{Binding SearchResults}"
                            SelectionMode="Single"
                            SelectionChanged="OnSongSelected"
                            ItemsLayout="VerticalList"
                            IsVisible="{Binding IsSearchActive}">
                <CollectionView.EmptyView>
                    <Label Text="No songs match your search."
                           TextColor="#8C76B5"
                           FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           Margin="0,40" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,1,0,1"
                                Padding="6,4,6,4"
                                Stroke="#4C327C"
                                StrokeThickness="1"
                                Background="#1A102A"
                                StrokeShape="RoundRectangle 6">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="1">
                                <Image Grid.RowSpan="3" Grid.ColumnSpan="2"
                                       Source="{Binding BackgroundImageSource}"
                                       Aspect="AspectFill"
                                       Opacity="0.2"
                                       HorizontalOptions="FillAndExpand"
                                       VerticalOptions="FillAndExpand" />
                                <BoxView Grid.RowSpan="3" Grid.ColumnSpan="2"
                                         BackgroundColor="#1A102A"
                                         Opacity="0.2" />
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                                       TextColor="#FFF4FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Artist}"
                                       FontSize="{OnPlatform Default=11, iOS=9, Android=9}"
                                       TextColor="#D0B7FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="2" Grid.Column="0"
                                       Text="{Binding ChartSummary}"
                                       FontSize="{OnPlatform Default=10, iOS=8, Android=8}"
                                       TextColor="#FFE76A"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Grid.RowSpan="3"
                                       Text="▶"
                                       FontSize="{OnPlatform Default=16, iOS=14, Android=14}"
                                       TextColor="#D94BFF"
                                       VerticalTextAlignment="Center"
                                       Margin="6,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Row 6: Selected song / chart panel -->
            <Border Grid.Row="6"
                    Background="#140A29"
                    Stroke="#3E2B72"
                    StrokeThickness="2"
                    Padding="{OnPlatform Default=12, iOS=8, Android=8}"
                    Margin="0,8,0,0"
                    IsVisible="{Binding HasSelection}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                    <VerticalStackLayout Grid.Column="0" Grid.Row="0" Spacing="2">
                        <Label x:Name="SelectedTitleLabel"
                               FontSize="{OnPlatform Default=18, iOS=16, Android=16}"
                               FontAttributes="Bold"
                               TextColor="#FFF4FF" />
                        <Label x:Name="SelectedArtistLabel"
                               FontSize="{OnPlatform Default=13, iOS=11, Android=11}"
                               TextColor="#D0B7FF" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Grid.Row="0"
                            x:Name="CloseButton"
                            Text="✕"
                            Clicked="OnCloseSelectionClicked"
                            BackgroundColor="#8B0000"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="{OnPlatform Default=16, iOS=14, Android=14}"
                            CornerRadius="8"
                            WidthRequest="{OnPlatform Default=35, iOS=30, Android=30}"
                            HeightRequest="{OnPlatform Default=35, iOS=30, Android=30}"
                            VerticalOptions="Start" />
                    <Grid Grid.Row="1" Grid.ColumnSpan="2"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="8"
                          VerticalOptions="Center">
                        <Picker Grid.Column="0"
                                x:Name="ChartPicker"
                                Title="Select chart"
                                SelectedIndexChanged="OnChartChanged"
                                TextColor="#FFF4FF"
                                TitleColor="#8C76B5"
                                FontSize="{OnPlatform Default=12, iOS=12, Android=12}"
                                HeightRequest="{OnPlatform Default=50, iOS=44, Android=44}"
                                VerticalOptions="Center" />
                    </Grid>
                    <Button Grid.Column="0" Grid.Row="2"
                            Grid.ColumnSpan="2"
                            x:Name="PlayButton"
                            Text="▶  PLAY"
                            Clicked="OnPlayClicked"
                            BackgroundColor="#D94BFF"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="{OnPlatform Default=20, iOS=18, Android=18}"
                            CornerRadius="14"
                            HeightRequest="{OnPlatform Default=56, iOS=50, Android=50}"
                            HorizontalOptions="FillAndExpand" />
                </Grid>
            </Border>

        </Grid>

        <!-- Landscape Layout -->
        <Grid x:Name="LandscapeLayout" IsVisible="False" Padding="16,8"
              RowDefinitions="Auto,Auto,Auto,Auto,*">

            <!-- Row 0: Header -->
            <VerticalStackLayout Grid.Row="0" Spacing="1" Margin="0,0,0,4">
                <Label Text="TAP IT UP"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#FFF4FF"
                       HorizontalTextAlignment="Center" />
                <Label Text="Select a song to play"
                       FontSize="12"
                       TextColor="#D0B7FF"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Row 1: Loading progress -->
            <VerticalStackLayout Grid.Row="1" Spacing="4">
                <Label x:Name="LoadingLabelLandscape"
                       Text=""
                       TextColor="#D0B7FF"
                       FontSize="12"
                       IsVisible="False"
                       HorizontalTextAlignment="Center"/>
                <ProgressBar x:Name="LoadingProgressBarLandscape"
                             Progress="0"
                             IsVisible="False"
                             HeightRequest="6"
                             BackgroundColor="#2A1B4A"
                             ProgressColor="#D94BFF"/>
            </VerticalStackLayout>

            <!-- Row 2: Navigation row + collapsible settings -->
            <Grid Grid.Row="2"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="4"
                  Margin="0,0,0,6">

                <!-- Navigation row: back, load buttons, search, commands toggle -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto,Auto,Auto,*,Auto"
                      ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="← Series"
                            Clicked="OnBackToSeriesClicked"
                            IsVisible="{Binding IsSongListVisible}"
                            BackgroundColor="#5D42E6"
                            TextColor="White"
                            CornerRadius="8"
                            WidthRequest="90"
                            HeightRequest="35"
                            FontSize="12" />
                    <Button Grid.Column="1"
                            Text="📁 Folder"
                            Clicked="OnOpenFolderClicked"
                            BackgroundColor="#5D42E6"
                            TextColor="White"
                            CornerRadius="8"
                            WidthRequest="90"
                            HeightRequest="35"
                            FontSize="12" />
                    <Button Grid.Column="2"
                            x:Name="LoadRemoteButtonLandscape"
                            Text="Load URL"
                            Clicked="OnLoadRemoteClicked"
                            CornerRadius="8"
                            HeightRequest="35"
                            FontSize="12"
                            WidthRequest="90" />
                    <Border Grid.Column="3"
                            Background="#1A102A"
                            Stroke="#4C327C"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="6,2">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="4">
                            <Label Grid.Column="0"
                                   Text="🔍"
                                   FontSize="14"
                                   TextColor="#8C76B5"
                                   VerticalTextAlignment="Center" />
                            <Entry Grid.Column="1"
                                   x:Name="LandscapeSearchEntry"
                                   Placeholder="Search all songs…"
                                   Text="{Binding SearchText}"
                                   TextChanged="OnSearchTextChanged"
                                   PlaceholderColor="#8C76B5"
                                   TextColor="#FFF4FF"
                                   BackgroundColor="Transparent"
                                   FontSize="12"
                                   ClearButtonVisibility="WhileEditing" />
                            <Label Grid.Column="2"
                                   Text="{Binding SearchResults.Count, StringFormat='{0} results'}"
                                   FontSize="11"
                                   TextColor="#8C76B5"
                                   VerticalTextAlignment="Center"
                                   IsVisible="{Binding IsSearchActive}" />
                        </Grid>
                    </Border>
                    <!-- Commands toggle -->
                    <Button Grid.Column="4"
                            Text="{Binding CommandsButtonText}"
                            Clicked="OnCommandsToggled"
                            BackgroundColor="#2A1B4A"
                            TextColor="#D0B7FF"
                            CornerRadius="8"
                            WidthRequest="110"
                            HeightRequest="35"
                            FontSize="12"
                            FontAttributes="Bold" />
                </Grid>

                <!-- Collapsible settings panel -->
                <Border Grid.Row="1"
                        IsVisible="{Binding IsSettingsVisible}"
                        Background="#1A102A"
                        Stroke="#4C327C"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="8,6">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="6">

                        <!-- Settings row 0: Speed, Skin, Judgment, Animations -->
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="10">
                            <Label Grid.Column="0"
                                   Text="Speed"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   VerticalTextAlignment="Center" />
                            <Slider Grid.Column="1"
                                    x:Name="LandscapeScrollSpeedSlider"
                                    Minimum="300"
                                    Maximum="999"
                                    Value="{Binding Av}"
                                    ValueChanged="OnAvChanged"
                                    ThumbColor="#D94BFF"
                                    MinimumTrackColor="#A100FF"
                                    MaximumTrackColor="#4C327C" />
                            <Label Grid.Column="2"
                                   x:Name="LandscapeScrollSpeedLabel"
                                   Text="{Binding AvText}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FFE76A"
                                   VerticalTextAlignment="Center"
                                   MinimumWidthRequest="55"
                                   HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3"
                                   Text="Skin"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   VerticalTextAlignment="Center" />
                            <Picker Grid.Column="4"
                                    x:Name="NoteSkinPickerLandscape"
                                    SelectedItem="{Binding NoteSkin}"
                                    TextColor="#FFF4FF"
                                    TitleColor="#8C76B5"
                                    FontSize="12"
                                    HeightRequest="35"
                                    WidthRequest="100">
                                <Picker.Items>
                                    <x:String>Prime</x:String>
                                    <x:String>Fiestaex</x:String>
                                    <x:String>Old</x:String>
                                    <x:String>NXA</x:String>
                                </Picker.Items>
                            </Picker>
                            <Label Grid.Column="5"
                                   Text="Judge"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   VerticalTextAlignment="Center" />
                            <Picker Grid.Column="6"
                                    SelectedItem="{Binding JudgmentDifficultyString}"
                                    TextColor="#FFF4FF"
                                    TitleColor="#8C76B5"
                                    FontSize="12"
                                    HeightRequest="35"
                                    WidthRequest="110">
                                <Picker.Items>
                                    <x:String>Standard</x:String>
                                    <x:String>Hard</x:String>
                                </Picker.Items>
                            </Picker>
                            <Label Grid.Column="7"
                                   Text="FX"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   VerticalTextAlignment="Center"
                                   ToolTipProperties.Text="Enable/disable animations" />
                            <Switch Grid.Column="8"
                                    x:Name="AnimationsSwitchLandscape"
                                    IsToggled="{Binding AnimationsEnabled}"
                                    OnColor="#D94BFF"
                                    ThumbColor="#FFF4FF"
                                    VerticalOptions="Center" />
                        </Grid>

                        <!-- Settings row 1: Audio offset -->
                        <Grid Grid.Row="1"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10">
                            <Label Grid.Column="0"
                                   Text="Audio Offset"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   VerticalTextAlignment="Center"
                                   ToolTipProperties.Text="Positive = arrows later (use for Bluetooth lag)" />
                            <Slider Grid.Column="1"
                                    x:Name="LandscapeAudioOffsetSlider"
                                    Minimum="-0"
                                    Maximum="4000"
                                    Value="{Binding AudioOffsetMs}"
                                    ValueChanged="OnAudioOffsetChanged"
                                    ThumbColor="#00C2FF"
                                    MinimumTrackColor="#0090CC"
                                    MaximumTrackColor="#4C327C" />
                            <Label Grid.Column="2"
                                   Text="{Binding AudioOffsetText}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#00C2FF"
                                   VerticalTextAlignment="Center"
                                   MinimumWidthRequest="68"
                                   HorizontalTextAlignment="Center" />
                        </Grid>

                    </Grid>
                </Border>
            </Grid>

            <!-- Row 3: Selected song panel -->
            <Border Grid.Row="3"
                    Background="#140A29"
                    Stroke="#3E2B72"
                    StrokeThickness="1"
                    Padding="8,6"
                    Margin="0,0,0,6"
                    StrokeShape="RoundRectangle 8"
                    IsVisible="{Binding HasSelection}">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                      ColumnSpacing="10"
                      VerticalOptions="Center">
                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                        <Label x:Name="LandscapeSelectedTitleLabel"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#FFF4FF"
                               LineBreakMode="TailTruncation"
                               MaxLines="1" />
                        <Label x:Name="LandscapeSelectedArtistLabel"
                               FontSize="10"
                               TextColor="#D0B7FF"
                               LineBreakMode="TailTruncation"
                               MaxLines="1" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1"
                           Text="Chart:"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#FCE3FF"
                           VerticalTextAlignment="Center" />
                    <Picker Grid.Column="2"
                            x:Name="LandscapeChartPicker"
                            SelectedIndexChanged="OnChartChanged"
                            TextColor="#FFF4FF"
                            FontSize="11"
                            WidthRequest="90"
                            HeightRequest="35"
                            VerticalOptions="Center" />
                    <Button Grid.Column="3"
                            Text="✕"
                            Clicked="OnCloseSelectionClicked"
                            BackgroundColor="#8B0000"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="14"
                            CornerRadius="8"
                            WidthRequest="35"
                            HeightRequest="35"
                            VerticalOptions="Center" />
                    <Button Grid.Column="4"
                            x:Name="LandscapePlayButton"
                            Text="PLAY"
                            Clicked="OnPlayClicked"
                            BackgroundColor="#D94BFF"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="13"
                            CornerRadius="10"
                            WidthRequest="70"
                            HeightRequest="35"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Row 4: Series selector landscape -->
            <CollectionView Grid.Row="4"
                x:Name="LandscapeSeriesCollectionView"
                ItemsSource="{Binding GameSeriesList}"
                SelectionMode="Single"
                SelectionChanged="OnSeriesSelected"
                IsVisible="{Binding IsSeriesViewVisible}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="#4C327C"
                                StrokeThickness="1"
                                Background="#1A102A"
                                StrokeShape="RoundRectangle 14"
                                Padding="0"
                                WidthRequest="160"
                                HeightRequest="100">
                            <Grid>
                                <Image Source="{Binding Banner}" Aspect="AspectFill" HorizontalOptions="Center" VerticalOptions="Center" />
                                <BoxView BackgroundColor="#000000" Opacity="0.4"/>
                                <Label Text="{Binding Name}"
                                       TextColor="White"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       Margin="0,0,0,8"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Row 4: Song list landscape -->
            <CollectionView Grid.Row="4"
                x:Name="LandscapeSongListView"
                ItemsSource="{Binding SongList}"
                SelectionMode="Single"
                SelectionChanged="OnSongSelected"
                ItemsLayout="HorizontalList"
                IsVisible="{Binding IsSongListVisible}">
                <CollectionView.EmptyView>
                    <Label Text="Loading song collection..."
                           TextColor="#8C76B5"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,6,0"
                                Padding="8"
                                Stroke="#4C327C"
                                StrokeThickness="1"
                                Background="#1A102A"
                                StrokeShape="RoundRectangle 8"
                                WidthRequest="200"
                                HeightRequest="90">
                            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="2">
                                <Image Grid.RowSpan="4"
                                       Source="{Binding BackgroundImageSource}"
                                       Aspect="AspectFill"
                                       Opacity="0.25"
                                       HorizontalOptions="FillAndExpand"
                                       VerticalOptions="FillAndExpand" />
                                <BoxView Grid.RowSpan="4"
                                         BackgroundColor="#1A102A"
                                         Opacity="0.2" />
                                <Label Grid.Row="0"
                                       Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="12"
                                       TextColor="#FFF4FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="1"
                                       Text="{Binding Artist}"
                                       FontSize="10"
                                       TextColor="#D0B7FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="2"
                                       Text="{Binding ChartSummary}"
                                       FontSize="9"
                                       TextColor="#FFE76A"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center" />
                                <Label Grid.Row="3"
                                       Text="▶ SELECT"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#D94BFF"
                                       HorizontalTextAlignment="Center"
                                       VerticalOptions="End" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Row 4: Search results landscape -->
            <CollectionView Grid.Row="4"
                x:Name="LandscapeSearchResultsView"
                ItemsSource="{Binding SearchResults}"
                SelectionMode="Single"
                SelectionChanged="OnSongSelected"
                ItemsLayout="HorizontalList"
                IsVisible="{Binding IsSearchActive}">
                <CollectionView.EmptyView>
                    <Label Text="No songs match your search."
                           TextColor="#8C76B5"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,6,0"
                                Padding="8"
                                Stroke="#4C327C"
                                StrokeThickness="1"
                                Background="#1A102A"
                                StrokeShape="RoundRectangle 8"
                                WidthRequest="200"
                                HeightRequest="90">
                            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="2">
                                <Image Grid.RowSpan="4"
                                       Source="{Binding BackgroundImageSource}"
                                       Aspect="AspectFill"
                                       Opacity="0.25"
                                       HorizontalOptions="FillAndExpand"
                                       VerticalOptions="FillAndExpand" />
                                <BoxView Grid.RowSpan="4"
                                         BackgroundColor="#1A102A"
                                         Opacity="0.2" />
                                <Label Grid.Row="0"
                                       Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="12"
                                       TextColor="#FFF4FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="1"
                                       Text="{Binding Artist}"
                                       FontSize="10"
                                       TextColor="#D0B7FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="2"
                                       Text="{Binding ChartSummary}"
                                       FontSize="9"
                                       TextColor="#FFE76A"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center" />
                                <Label Grid.Row="3"
                                       Text="▶ SELECT"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#D94BFF"
                                       HorizontalTextAlignment="Center"
                                       VerticalOptions="End" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>