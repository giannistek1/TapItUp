<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="TapItUp.GamePage"
             BackgroundColor="#05010F"
             NavigationPage.HasNavigationBar="False">

    <Grid x:Name="MainGrid">

        <!-- Portrait Layout -->
        <Grid x:Name="PortraitLayout"
              IsVisible="True"
              Padding="{OnPlatform Default=12, iOS=6, Android=6}"
              IsClippedToBounds="True">

            <!-- Background fills the full portrait area, behind everything else -->
            <Image x:Name="BackgroundPreview"
                   Aspect="AspectFill"
                   Opacity="0.15"
                   HorizontalOptions="FillAndExpand"
                   VerticalOptions="FillAndExpand" />

            <!-- Note field — NoteFieldDrawable draws its own opaque dark background,
                 so the song background shows only in the surrounding area -->
            <Grid HorizontalOptions="Center"
                  VerticalOptions="Start"
                  WidthRequest="180"
                  HeightRequest="480"
                  IsClippedToBounds="True">

                <GraphicsView x:Name="NoteFieldView"
                              HorizontalOptions="Fill"
                              VerticalOptions="Fill" />
            </Grid>

            <!-- Exit button positioned at top right -->
            <Button Text="✕"
                    Clicked="OnStopClicked"
                    BackgroundColor="#4B275E"
                    TextColor="White"
                    CornerRadius="8"
                    WidthRequest="{OnPlatform Default=40, iOS=35, Android=35}"
                    HeightRequest="{OnPlatform Default=40, iOS=35, Android=35}"
                    FontSize="{OnPlatform Default=16, iOS=14, Android=14}"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,10,10,0" />

            <!-- Portrait Pad -->
            <Grid x:Name="PortraitPad"
                  HorizontalOptions="Center"
                  VerticalOptions="End"
                  Margin="{OnPlatform Default='0,0,0,10', iOS='0,0,0,5', Android='0,0,0,5'}" />

            <!-- Combo counter — centred, slightly below mid -->
            <StackLayout HorizontalOptions="Center"
                         VerticalOptions="Center"
                         Margin="0,80,0,0"
                         Spacing="4">
                <Label x:Name="CenterComboTextLabel"
                       Text="COMBO"
                       FontSize="{OnPlatform Default=20, iOS=16, Android=16}"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       IsVisible="False"
                       Opacity="0.8"
                       Shadow="{Shadow Brush=Black, Offset='1,1', Radius=4, Opacity=0.8}" />
                <Label x:Name="CenterComboNumberLabel"
                       Text="4"
                       FontSize="{OnPlatform Default=42, iOS=36, Android=36}"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       IsVisible="False"
                       Opacity="0.9"
                       Shadow="{Shadow Brush=Black, Offset='2,2', Radius=8, Opacity=0.8}" />
            </StackLayout>

            <!-- Judgment label — independent overlay, above combo, near top-center -->
            <Label x:Name="CenterJudgmentLabel"
                   FontSize="{OnPlatform Default=40, iOS=32, Android=32}"
                   FontAttributes="Bold"
                   TextColor="#FFE76A"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,-100,0,0"
                   IsVisible="False"
                   Opacity="0.9"
                   Shadow="{Shadow Brush=Black, Offset='2,2', Radius=8, Opacity=0.8}" />

            <!-- Stats overlay -->
            <Label x:Name="PortraitCountsLabel"
                   Text="PERFECT 0 • GREAT 0 • GOOD 0 • BAD 0 • MISS 0"
                   FontSize="{OnPlatform Default=10, iOS=8, Android=8}"
                   TextColor="#D0B7FF"
                   HorizontalTextAlignment="Center"
                   VerticalOptions="End"
                   Margin="0,0,0,2"
                   Opacity="0.8"
                   Shadow="{Shadow Brush=Black, Offset='1,1', Radius=4, Opacity=0.8}" />

            <!-- Invisible text entry for keyboard input -->
            <Entry x:Name="KeyCatcher"
                   IsVisible="False"
                   TextChanged="KeyCatcher_TextChanged"
                   Unfocused="KeyCatcher_Unfocused" />

            <!-- Portrait health bar — pinned to the very top -->
            <ContentView x:Name="PortraitHealthContainer"
                         HorizontalOptions="Fill"
                         VerticalOptions="Start"
                         Margin="8,4,8,0" />
        </Grid>

        <!-- Landscape Layout -->
        <Grid x:Name="LandscapeLayout"
              IsVisible="False"
              ColumnDefinitions="*,Auto,*"
              RowDefinitions="Auto,*,Auto">

            <!-- Health bar spans full width at the very top row (Row 0) -->
            <ContentView x:Name="LandscapeHealthContainer"
                         Grid.Row="0"
                         Grid.ColumnSpan="3"
                         HorizontalOptions="Fill"
                         Margin="8,4,8,0" />

            <!-- Exit button positioned at top right - Fixed positioning -->
            <Button Grid.Row="1"
                    Grid.Column="2"
                    Text="✕"
                    Clicked="OnStopClicked"
                    BackgroundColor="#4B275E"
                    TextColor="White"
                    CornerRadius="8"
                    WidthRequest="40"
                    HeightRequest="40"
                    FontSize="16"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,10,10,0"
                    ZIndex="200" />

            <!-- Left side - Scaling pad area -->
            <Grid Grid.Column="0" Grid.Row="1"
                  Padding="8,8,8,4"
                  MinimumWidthRequest="120"
                  ZIndex="10">

                <!-- Left input pad - Scales with available space -->
                <Grid x:Name="LandscapeLeftPad"
                      HorizontalOptions="Fill"
                      VerticalOptions="End"
                      Margin="0,8,0,0" />
            </Grid>

            <!-- Center - note field, sits behind pads -->
            <Grid Grid.Column="1" Grid.Row="1"
                  x:Name="LandscapeCenterGrid"
                  Margin="0"
                  IsClippedToBounds="True"
                  ZIndex="1">

                <!-- Background for center area only -->
                <Image x:Name="LandscapeBackgroundPreview"
                       Aspect="AspectFill"
                       Opacity="0.2"
                       HorizontalOptions="FillAndExpand"
                       VerticalOptions="FillAndExpand" />

                <!-- Note field -->
                <GraphicsView x:Name="LandscapeNoteFieldView"
                              WidthRequest="180"
                              HeightRequest="480"
                              HorizontalOptions="Center"
                              VerticalOptions="Start" />

                <!-- Combo counter -->
                <StackLayout HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Margin="0,60,0,0"
                             Spacing="3">
                    <Label x:Name="LandscapeCenterComboTextLabel"
                           Text="COMBO"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           IsVisible="False"
                           Opacity="0.8"
                           Shadow="{Shadow Brush=Black, Offset='1,1', Radius=4, Opacity=0.8}" />
                    <Label x:Name="LandscapeCenterComboNumberLabel"
                           Text="4"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           IsVisible="False"
                           Opacity="0.9"
                           Shadow="{Shadow Brush=Black, Offset='2,2', Radius=8, Opacity=0.8}" />
                </StackLayout>

                <!-- Judgment label — independent overlay above combo -->
                <Label x:Name="LandscapeCenterJudgmentLabel"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#FFE76A"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,-80,0,0"
                       IsVisible="False"
                       Opacity="0.9"
                       Shadow="{Shadow Brush=Black, Offset='2,2', Radius=8, Opacity=0.8}" />
            </Grid>

            <!-- Right side - Scaling pad area -->
            <Grid Grid.Column="2" Grid.Row="1"
                  Padding="8,8,8,4"
                  MinimumWidthRequest="120"
                  ZIndex="10">

                <!-- Right input pad - Scales with available space -->
                <Grid x:Name="LandscapeRightPad"
                      HorizontalOptions="Fill"
                      VerticalOptions="End"
                      Margin="0,8,0,0" />
            </Grid>

            <!-- Bottom stats across full width -->
            <Border Grid.Row="2" Grid.ColumnSpan="3"
                    Background="#140A29"
                    Stroke="#3E2B72"
                    StrokeThickness="1"
                    Padding="6"
                    Margin="4,8,4,0">

                <Label x:Name="LandscapeCountsLabel"
                       Text="PERFECT 0 • GREAT 0 • GOOD 0 • BAD 0 • MISS 0"
                       FontSize="10"
                       TextColor="#D0B7FF"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="TailTruncation" />
            </Border>
        </Grid>

        <!-- Audio player -->
        <toolkit:MediaElement x:Name="SongMediaElement"
                              IsVisible="False"
                              ShouldAutoPlay="False" />
    </Grid>
</ContentPage>