<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PumpMaui.SongSelectPage"
             Title="Song Select"
             BackgroundColor="#05010F"
             NavigationPage.HasNavigationBar="False">

    <Grid x:Name="MainGrid">
        <!-- Portrait Layout -->
        <Grid x:Name="PortraitLayout" 
              IsVisible="True"
              Padding="{OnPlatform Default=16, iOS=8, Android=8}" 
              RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">

            <!-- Header - Responsive sizing -->
            <VerticalStackLayout Grid.Row="0" Spacing="1" Margin="0,0,0,4">
                <Label Text="PUMP MAUI"
                       FontSize="{OnPlatform Default=24, iOS=20, Android=20}"
                       FontAttributes="Bold"
                       TextColor="#FFF4FF"
                       HorizontalTextAlignment="Center" />
                <Label Text="Select a series and song to play"
                       FontSize="{OnPlatform Default=12, iOS=10, Android=10}"
                       TextColor="#D0B7FF"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Load buttons - Responsive layout -->
            <HorizontalStackLayout Grid.Row="1" Spacing="8" HorizontalOptions="Center" Margin="0,0,0,4">
                <Button Text="External Folder"
                        Clicked="OnOpenFolderClicked"
                        BackgroundColor="#5D42E6"
                        TextColor="White"
                        CornerRadius="10"
                        WidthRequest="{OnPlatform Default=160, iOS=140, Android=140}"
                        HeightRequest="{OnPlatform Default=44, iOS=40, Android=40}"
                        FontSize="{OnPlatform Default=14, iOS=12, Android=12}" />

                <Button x:Name="LoadRemoteButtonPortrait" Text="Load from URL" Clicked="OnLoadRemoteClicked" />
            </HorizontalStackLayout>

            <VerticalStackLayout Grid.Row="2" Spacing="4">

                <Label x:Name="LoadingLabelPortrait"
                       Text=""
                       TextColor="#D0B7FF"
                       FontSize="12"
                       IsVisible="False"
                       HorizontalTextAlignment="Center"/>

                <ProgressBar x:Name="LoadingProgressBarPortrait"
                     Progress="0"
                     IsVisible="False"
                     HeightRequest="6"
                     BackgroundColor="#2A1B4A"
                     ProgressColor="#D94BFF"/>

            </VerticalStackLayout>

            <!-- Settings like scroll speed and skin -->
            <Border Grid.Row="3"
                    Background="#1A102A"
                    Stroke="#4C327C"
                    StrokeThickness="1"
                    Padding="{OnPlatform Default=12, iOS=8, Android=8}"
                    Margin="0,0,0,8"
                    StrokeShape="RoundRectangle 8">

                <Grid RowDefinitions="Auto, Auto">

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                        <Label Grid.Column="0"
                        Text="Scroll Speed"
                        FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                        FontAttributes="Bold"
                        TextColor="#FCE3FF"
                        VerticalTextAlignment="Center" />
                                    <Slider Grid.Column="1"
                            x:Name="ScrollSpeedSlider"
                            Minimum="0.5"
                            Maximum="4.0"
                            Value="{Binding ScrollSpeed}"
                            ValueChanged="OnScrollSpeedChanged"
                            ThumbColor="#D94BFF"
                            MinimumTrackColor="#A100FF"
                            MaximumTrackColor="#4C327C" />
                                    <Label Grid.Column="2"
                        x:Name="ScrollSpeedLabel"
                        Text="{Binding ScrollSpeedText}"
                        FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                        FontAttributes="Bold"
                        TextColor="#FFE76A"
                        VerticalTextAlignment="Center"
                        MinimumWidthRequest="40"
                        HorizontalTextAlignment="Center" />

                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="Auto, Auto" ColumnSpacing="12">
                        <!-- Note Skin Selector - Portrait -->
                        <Label
                            Text="Note Skin"
                            FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                            FontAttributes="Bold"
                            TextColor="#FCE3FF"
                            VerticalTextAlignment="Center" />
                        
                        <Picker Grid.Column="1"
                                x:Name="NoteSkinPicker"
                                SelectedItem="{Binding NoteSkin}"
                                TextColor="#FFF4FF"
                                TitleColor="#8C76B5"
                                FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                                HeightRequest="{OnPlatform Default=40, iOS=35, Android=35}"
                                WidthRequest="100">
                            <Picker.Items>
                                <x:String>Prime</x:String>
                                <x:String>Fiesta2</x:String>
                                <x:String>Old</x:String>
                                <x:String>NXA</x:String>
                            </Picker.Items>
                        </Picker>
                        
                    </Grid>

                </Grid>
               
            </Border>

            <!-- Game Series Selector -->
            <CollectionView Grid.Row="4"
                x:Name="PortraitSeriesCollectionView"
                ItemsSource="{Binding GameSeriesList}"
                SelectionMode="Single"
                SelectionChanged="OnSeriesSelected"   
                IsVisible="{Binding IsSeriesSelectionVisible}">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="#4C327C"
                                StrokeThickness="1"
                                Background="#1A102A"
                                StrokeShape="RoundRectangle 16"
                                Padding="0"
                                WidthRequest="180"
                                HeightRequest="120">

                            <Grid>
                                <!-- Banner -->
                                <Image Source="{Binding Banner}" Aspect="AspectFill" />

                                <!-- Overlay -->
                                <BoxView BackgroundColor="#000000" Opacity="0.4"/>

                                <!-- Title -->
                                <Label Text="{Binding Name}"
                           TextColor="White"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="End"
                           Margin="0,0,0,10"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Song list - Vertical -->
            <CollectionView Grid.Row="4"
                            x:Name="SongListView"
                            ItemsSource="{Binding SongList}"
                            SelectionMode="Single"
                            SelectionChanged="OnSongSelected"
                            ItemsLayout="VerticalList"
                            IsVisible="{Binding IsSongListVisible}">
                <CollectionView.EmptyView>
                    <Label Text="Loading song collection..."
                           TextColor="#8C76B5"
                           FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           Margin="0,40" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,1,0,1"
                                Padding="6,4,6,4"
                                Stroke="#4C327C"
                                StrokeThickness="1"
                                Background="#1A102A"
                                StrokeShape="RoundRectangle 6">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto"
                                  RowSpacing="1">
                                <!-- Background Image -->
                                <Image Grid.RowSpan="3" Grid.ColumnSpan="2"
                                       Source="{Binding BackgroundImageSource}"
                                       Aspect="AspectFill"
                                       Opacity="0.2"
                                       HorizontalOptions="FillAndExpand"
                                       VerticalOptions="FillAndExpand" />
                                
                                <!-- Semi-transparent overlay for better text readability -->
                                <BoxView Grid.RowSpan="3" Grid.ColumnSpan="2"
                                         BackgroundColor="#1A102A"
                                         Opacity="0.7" />
                                
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                                       TextColor="#FFF4FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Artist}"
                                       FontSize="{OnPlatform Default=11, iOS=9, Android=9}"
                                       TextColor="#D0B7FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="2" Grid.Column="0"
                                       Text="{Binding ChartSummary}"
                                       FontSize="{OnPlatform Default=10, iOS=8, Android=8}"
                                       TextColor="#FFE76A"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Grid.RowSpan="3"
                                       Text="▶"
                                       FontSize="{OnPlatform Default=16, iOS=14, Android=14}"
                                       TextColor="#D94BFF"
                                       VerticalTextAlignment="Center"
                                       Margin="6,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>


            <Button Grid.Row="5"
                    Text="← Back to Series"
                    Clicked="OnBackToSeriesClicked"
                    BackgroundColor="#5D42E6"
                    TextColor="White"
                    CornerRadius="10"
                    IsVisible="{Binding IsSongListVisible}" />

            <!-- Selected song / chart panel - Portrait -->
            <Border Grid.Row="6"
                    Background="#140A29"
                    Stroke="#3E2B72"
                    StrokeThickness="2"
                    Padding="{OnPlatform Default=12, iOS=8, Android=8}"
                    Margin="0,8,0,0"
                    IsVisible="{Binding HasSelection}">
                <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                    
                    <!-- Song Info -->
                    <VerticalStackLayout Grid.Column="0" Grid.Row="0" Spacing="2">
                        <Label x:Name="SelectedTitleLabel"
                               FontSize="{OnPlatform Default=18, iOS=16, Android=16}"
                               FontAttributes="Bold"
                               TextColor="#FFF4FF" />
                        <Label x:Name="SelectedArtistLabel"
                               FontSize="{OnPlatform Default=13, iOS=11, Android=11}"
                               TextColor="#D0B7FF" />
                    </VerticalStackLayout>

                    <!-- Chart Picker -->
                    <VerticalStackLayout Grid.Column="0" Grid.Row="1" Spacing="4">
                        <Label Text="Chart" FontAttributes="Bold" TextColor="#FCE3FF" 
                               FontSize="{OnPlatform Default=12, iOS=10, Android=10}" />
                        <Picker x:Name="ChartPicker"
                                Title="Select chart"
                                SelectedIndexChanged="OnChartChanged"
                                TextColor="#FFF4FF"
                                TitleColor="#8C76B5"
                                FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                                HeightRequest="{OnPlatform Default=40, iOS=35, Android=35}" />
                    </VerticalStackLayout>

                    <!-- Selected Chart Display -->
                    <Border Grid.Column="0" Grid.Row="2" 
                            Grid.ColumnSpan="3"
                            Background="#2A1B4A"
                            Stroke="#D94BFF"
                            StrokeThickness="1"
                            Padding="8"
                            StrokeShape="RoundRectangle 6"
                            x:Name="SelectedChartBorder"
                            IsVisible="False">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    Background="#D94BFF"
                                    Padding="4,2"
                                    StrokeShape="RoundRectangle 3">
                                <Label x:Name="SelectedChartDifficultyLabel"
                                       Text="HARD"
                                       FontSize="{OnPlatform Default=10, iOS=9, Android=9}"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                            </Border>
                            
                            <Label Grid.Column="1"
                                   x:Name="SelectedChartLevelLabel"
                                   Text="Level 12"
                                   FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                                   FontAttributes="Bold"
                                   TextColor="#FFE76A"
                                   VerticalTextAlignment="Center" />
                            
                            <Label Grid.Column="2"
                                   x:Name="SelectedChartNotesLabel"
                                   Text="456 notes"
                                   FontSize="{OnPlatform Default=12, iOS=10, Android=10}"
                                   TextColor="#D0B7FF"
                                   VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Close Button -->
                    <Button Grid.Column="1"
                            Grid.Row="0"
                            x:Name="CloseButton"
                            Text="✕"
                            Clicked="OnCloseSelectionClicked"
                            BackgroundColor="#8B0000"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="{OnPlatform Default=16, iOS=14, Android=14}"
                            CornerRadius="8"
                            WidthRequest="{OnPlatform Default=35, iOS=30, Android=30}"
                            HeightRequest="{OnPlatform Default=35, iOS=30, Android=30}"
                            VerticalOptions="Start"
                            Margin="0,0,8,0" />

                    <!-- Play Button -->
                    <Button Grid.Column="2"
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            x:Name="PlayButton"
                            Text="PLAY"
                            Clicked="OnPlayClicked"
                            BackgroundColor="#D94BFF"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="{OnPlatform Default=18, iOS=16, Android=16}"
                            CornerRadius="14"
                            WidthRequest="{OnPlatform Default=90, iOS=80, Android=80}"
                            HeightRequest="{OnPlatform Default=70, iOS=60, Android=60}"
                            VerticalOptions="Center" />
                </Grid>
            </Border>
        </Grid>

        <!-- Landscape Layout -->
        <Grid x:Name="LandscapeLayout" IsVisible="False" Padding="16,8" RowDefinitions="Auto,Auto,Auto,*">

            <!-- Header - Compact for landscape -->
            <VerticalStackLayout Grid.Row="0" Spacing="1" Margin="0,0,0,8">
                <Label Text="PUMP MAUI"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#FFF4FF"
                       HorizontalTextAlignment="Center" />
                <Label Text="Select a song to play"
                       FontSize="12"
                       TextColor="#D0B7FF"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="1" Spacing="4">

                <Label x:Name="LoadingLabelLandscape"
                               Text=""
                               TextColor="#D0B7FF"
                               FontSize="12"
                               IsVisible="False"
                               HorizontalTextAlignment="Center"/>

                <ProgressBar x:Name="LoadingProgressBarLandscape"
                             Progress="0"
                             IsVisible="False"
                             HeightRequest="6"
                             BackgroundColor="#2A1B4A"
                             ProgressColor="#D94BFF"/>

            </VerticalStackLayout>

            <!-- Controls Row - Updated with chart selection and note skin -->
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,0,0,8">

                <!-- Left Controls -->
                <HorizontalStackLayout Grid.Column="0" Spacing="12">
                    <Button Text="← Series"
                        Clicked="OnBackToSeriesClicked"
                        IsVisible="{Binding IsSongListVisible}"
                        BackgroundColor="#5D42E6"
                        TextColor="White"
                        WidthRequest="100"
                        HeightRequest="35"/>

                    <!-- Load buttons - Compact -->
                    <Button Text="External Folder"
                            Clicked="OnOpenFolderClicked"
                            BackgroundColor="#5D42E6"
                            TextColor="White"
                            CornerRadius="8"
                            WidthRequest="120"
                            HeightRequest="35"
                            FontSize="12" />

                    <Button x:Name="LoadRemoteButtonLandscape" HeightRequest="35" Text="Load from URL" Clicked="OnLoadRemoteClicked" />

                    <!-- Scroll Speed Slider - Inline -->
                    <Border Background="#1A102A"
                            Stroke="#4C327C"
                            StrokeThickness="1"
                            Padding="8"
                            StrokeShape="RoundRectangle 6"
                            WidthRequest="200">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                            <Label Grid.Column="0"
                                   Text="Speed"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   VerticalTextAlignment="Center" />
                            <Slider Grid.Column="1"
                                    x:Name="LandscapeScrollSpeedSlider"
                                    Minimum="0.5"
                                    Maximum="4.0"
                                    Value="{Binding ScrollSpeed}"
                                    ValueChanged="OnScrollSpeedChanged"
                                    ThumbColor="#D94BFF"
                                    MinimumTrackColor="#A100FF"
                                    MaximumTrackColor="#4C327C" />
                            <Label Grid.Column="2"
                                   x:Name="LandscapeScrollSpeedLabel"
                                   Text="{Binding ScrollSpeedText}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FFE76A"
                                   VerticalTextAlignment="Center"
                                   MinimumWidthRequest="30"
                                   HorizontalTextAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Note Skin Selector - Landscape -->
                    <Label Grid.Column="3"
                           Text="Note Skin"
                           FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                           FontAttributes="Bold"
                           TextColor="#FCE3FF"
                           VerticalTextAlignment="Center" />
                    <Picker Grid.Column="4"
                            x:Name="NoteSkinPickerLandscape"
                            SelectedItem="{Binding NoteSkin}"
                            TextColor="#FFF4FF"
                            TitleColor="#8C76B5"
                            FontSize="{OnPlatform Default=14, iOS=12, Android=12}"
                            HeightRequest="{OnPlatform Default=40, iOS=35, Android=35}"
                            WidthRequest="100">
                        <Picker.Items>
                            <x:String>Prime</x:String>
                            <x:String>Fiesta2</x:String>
                            <x:String>Old</x:String>
                            <x:String>NXA</x:String>
                        </Picker.Items>
                    </Picker>
                </HorizontalStackLayout>

                <!-- Right Controls - Chart Selection -->
                <HorizontalStackLayout Grid.Column="1" 
                                       Spacing="8" 
                                       IsVisible="{Binding HasSelection}"
                                       VerticalOptions="Center">

                    <!-- Song Info - Compact -->
                    <Border Background="#140A29"
                            Stroke="#3E2B72"
                            StrokeThickness="1"
                            Padding="8"
                            StrokeShape="RoundRectangle 6"
                            MaximumWidthRequest="200">
                        <VerticalStackLayout Spacing="2">
                            <Label x:Name="LandscapeSelectedTitleLabel"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FFF4FF"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1" />
                            <Label x:Name="LandscapeSelectedArtistLabel"
                                   FontSize="10"
                                   TextColor="#D0B7FF"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Chart Picker -->
                    <Border Background="#2A1B4A"
                            Stroke="#D94BFF"
                            StrokeThickness="1"
                            Padding="6"
                            StrokeShape="RoundRectangle 6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="Chart:"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   TextColor="#FCE3FF"
                                   VerticalTextAlignment="Center" />
                            <Picker x:Name="LandscapeChartPicker"
                                    SelectedIndexChanged="OnChartChanged"
                                    TextColor="#FFF4FF"
                                    FontSize="11"
                                    WidthRequest="80"
                                    HeightRequest="30" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Play Button -->
                    <Button x:Name="LandscapePlayButton"
                            Text="PLAY"
                            Clicked="OnPlayClicked"
                            BackgroundColor="#D94BFF"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="12"
                            CornerRadius="8"
                            WidthRequest="60"
                            HeightRequest="35" />
                </HorizontalStackLayout>
            </Grid>

            <!-- Game Series Selector - Landscape -->
            <CollectionView Grid.Row="3"
                            x:Name="LandscapeSeriesCollectionView"
                            ItemsSource="{Binding GameSeriesList}"
                            SelectionMode="Single"
                            SelectionChanged="OnSeriesSelected"
                            HeightRequest="120"
                            IsVisible="{Binding IsSeriesSelectionVisible}">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="#4C327C"
                                StrokeThickness="1"
                                Background="#1A102A"
                                StrokeShape="RoundRectangle 14"
                                Padding="0"
                                WidthRequest="160"
                                HeightRequest="100">

                            <Grid>
                                <Image Source="{Binding Banner}"  Aspect="AspectFill"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />

                                <BoxView BackgroundColor="#000000" Opacity="0.4"/>

                                <Label Text="{Binding Name}"
                                   TextColor="White"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Margin="0,0,0,8"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Song list - Full width horizontal -->
            <CollectionView Grid.Row="3"
                            x:Name="LandscapeSongListView"
                            ItemsSource="{Binding SongList}"
                            SelectionMode="Single"
                            SelectionChanged="OnSongSelected"
                            ItemsLayout="HorizontalList"
                            IsVisible="{Binding IsSongListVisible}">
                
                <CollectionView.EmptyView>
                    <Label Text="Loading song collection..."
                           TextColor="#8C76B5"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </CollectionView.EmptyView>
                
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,6,0"
                                Padding="8"
                                Stroke="#4C327C"
                                StrokeThickness="1"
                                Background="#1A102A"
                                StrokeShape="RoundRectangle 8"
                                WidthRequest="240"
                                HeightRequest="100">
                            
                            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="2">
                                <!-- Background Image -->
                                <Image Grid.RowSpan="4"
                                       Source="{Binding BackgroundImageSource}"
                                       Aspect="AspectFill"
                                       Opacity="0.25"
                                       HorizontalOptions="FillAndExpand"
                                       VerticalOptions="FillAndExpand" />
                                
                                <!-- Semi-transparent overlay for better text readability -->
                                <BoxView Grid.RowSpan="4"
                                         BackgroundColor="#1A102A"
                                         Opacity="0.6" />
                                
                                <Label Grid.Row="0"
                                       Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="12"
                                       TextColor="#FFF4FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="1"
                                       Text="{Binding Artist}"
                                       FontSize="10"
                                       TextColor="#D0B7FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Row="2"
                                       Text="{Binding ChartSummary}"
                                       FontSize="9"
                                       TextColor="#FFE76A"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center" />
                                <Label Grid.Row="3"
                                       Text="▶ SELECT"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="#D94BFF"
                                       HorizontalTextAlignment="Center"
                                       VerticalOptions="End" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>